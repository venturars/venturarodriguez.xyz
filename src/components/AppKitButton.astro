---
import WalletIcon from "./icons/WalletIcon.astro";
import EN from "../locales/EN.json";

const locales = EN.components.appKitButton;
---

<script>
  import { getConnection, watchConnection } from "@wagmi/core";
  import { appKitModal } from "../libs/appkitModal";
  import { setupWalletStoreSync } from "../libs/walletSync";
  import { wagmiConfig } from "../libs/web3";

  /**
   * Reflects wallet connection state in button icon + label.
   *
   * - Connected: shows truncated address and wallet icon.
   * - Disconnected: shows connect prompt and hides wallet icon.
   */
  function updateButtonState() {
    const address = getConnection(wagmiConfig)?.address;
    const connectWalletText = connectBtn?.dataset.connectWalletText ?? "";
    if (connectBtnText) {
      connectBtnText.textContent = address
        ? `${address.slice(0, 6)}…${address.slice(-4)}`
        : connectWalletText;
    }
    if (connectBtnIcon) {
      connectBtnIcon.style.display = address ? "" : "none";
    }
  }

  const connectBtn = document.getElementById("connect-wallet-btn");
  const connectBtnIcon = document.getElementById("connect-wallet-btn-icon");
  const connectBtnText = document.getElementById("connect-wallet-btn-text");

  connectBtn?.addEventListener("click", () => appKitModal.open());

  setupWalletStoreSync();

  updateButtonState();

  watchConnection(wagmiConfig, {
    onChange() {
      updateButtonState();
    },
  });
</script>

<button
  id="connect-wallet-btn"
  class="link link-primary inline-flex max-w-full items-center gap-1.5 whitespace-normal wrap-break-word text-right text-sm leading-tight no-underline md:text-base"
  data-connect-wallet-text={locales.connectWallet}
>
  <span id="connect-wallet-btn-icon" style="display: none">
    <WalletIcon class="size-5 shrink-0" />
  </span>
  <span id="connect-wallet-btn-text">{locales.connectWallet}</span>
</button>
