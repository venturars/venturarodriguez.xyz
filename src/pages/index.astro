---
import MainLayout from "../layouts/Main.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import EN from "../locales/EN.json";
---

<MainLayout
  title={EN.pages.landing.title}
  description={EN.pages.landing.description}
>
  <Header />
  <div
    class="md:h-[calc(100vh-3.5rem-3.5rem)] h-[calc(100vh-152px-3rem)] min-h-max w-screen bg-primary text-base-200"
  >
    <div class="flex items-center justify-center h-full gap-4">
      {
        EN.pages.landing.tools.map((tool) => (
          <a href="/swaps" class="btn btn-ghost btn-xl outline outline-neutral">
            {tool}
          </a>
        ))
      }
    </div>
  </div>
  <Footer />
</MainLayout>
